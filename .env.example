# ─── Outscraper ───────────────────────────────────────────────────────────────
# Sign up at outscraper.com (no credit card required for free tier)
# Go to: Profile → API Key
OUTSCRAPER_API_KEY=

# ─── Apify ────────────────────────────────────────────────────────────────────
# Sign up at apify.com ($5/month free credit)
# Go to: console.apify.com → Account → Integrations → API token
APIFY_TOKEN=

# ─── Firecrawl ────────────────────────────────────────────────────────────────
# Get from: firecrawl.dev dashboard (1,000 credits/month refreshed)
FIRECRAWL_API_KEY=

# ─── Google AI Studio (Gemini — FREE) ─────────────────────────────────────────
# Go to: aistudio.google.com → Get API key (no credit card required)
GEMINI_API_KEY=

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Create the "MWJ Competitor Intelligence" sheet, share with your Google account
# Get from the sheet URL: docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Create "MWJ Competitor Reports" folder in Drive
# Get from folder URL: drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DOCS_FOLDER_ID=

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# Files are created as your actual Google account (no service account needed).
# Setup steps:
# 1. GCP Console → APIs & Services → Credentials → Create OAuth client ID
#    - Application type: Web application
#    - Authorized redirect URI: http://localhost:3737/oauth2callback
# 2. Copy Client ID and Client Secret below
# 3. Run: node get-refresh-token.mjs
#    - Opens a browser auth flow as your Google account
#    - Paste the printed refresh token below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── ClickUp ──────────────────────────────────────────────────────────────────
# API Token: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=
# Workspace ID: first number in any ClickUp URL (app.clickup.com/{WORKSPACE_ID}/...)
CLICKUP_WORKSPACE_ID=
# Folder ID: open the "Competitor Intelligence" folder → from URL .../v/f/{FOLDER_ID}
CLICKUP_FOLDER_ID=
# List ID: open the "Weekly Competitor Tasks" list → from URL .../v/li/{LIST_ID}
CLICKUP_LIST_ID=

# ─── Scan Mode ────────────────────────────────────────────────────────────────
# "demo" = proof of concept, stays within all free tiers ($0 cash)
# "full" = hybrid deep-monthly / light-weekly (~$15–20/month)
SCAN_MODE=demo
